{
    "name": "animeav1-api",
    "version": "1.2.1",
    "description": "API no oficial para scrapear datos de AnimeAV1",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "type": "module",
    "files": [
        "dist/",
        "README.md",
        "AGENTS.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
    },
    "keywords": [
        "anime",
        "scraper",
        "api",
        "animeav1"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsup": "^8.0.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "cheerio": "^1.0.0"
    }
}
